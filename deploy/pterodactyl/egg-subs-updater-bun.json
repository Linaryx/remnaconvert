  "scripts": {
    "installation": {
      "script": "#!/bin/ash\nset -e\napk add --no-cache git ca-certificates >/dev/null\n: \"${REPO_URL:?REPO_URL is required}\"\nREPO_BRANCH=\"${REPO_BRANCH:-main}\"\nmkdir -p /mnt/server\nif [ -d /mnt/server/.git ]; then\n  cd /mnt/server\n  git fetch --depth=1 origin \"${REPO_BRANCH}\"\n  git reset --hard FETCH_HEAD\nelse\n  rm -rf /mnt/server/*\n  git clone --depth=1 --branch \"${REPO_BRANCH}\" \"${REPO_URL}\" /mnt/server\nfi\ncd /mnt/server\nif [ ! -f subscription-service.js ] || [ ! -f convert-oversub-to-v2ray.js ]; then\n  echo \"Missing required files in repo root: subscription-service.js, convert-oversub-to-v2ray.js\"\n  exit 1\nfi\necho \"Install complete from ${REPO_URL}#${REPO_BRANCH}\"\n",
      "container": "alpine:3.20",
      "entrypoint": "ash"
    }
  },
